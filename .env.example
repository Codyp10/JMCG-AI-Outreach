# Supabase (Vercel workers use service role — never expose in browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio — Gemini API (copy-generate + reply-agent classification)
# Create key: https://aistudio.google.com/apikey — add to Vercel and redeploy.
GEMINI_API_KEY=
# Optional override; default is gemini-2.5-flash (see src/lib/gemini/generate.ts).
# GEMINI_MODEL=gemini-2.5-flash

# Instantly API v2 — Bearer token in Authorization header (not query params)
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=

# Shared secrets
CRON_SECRET=

# Optional: HVAC score geo allowlist (comma or newline separated) — see src/app/api/workers/score/route.ts
# GEO_ALLOWLIST=Texas,Austin

# Slack (escalations + monthly summary)
SLACK_WEBHOOK_URL=

# Enrichment providers (waterfall worker)
ENRICHMENT_CLAY_API_KEY=
ENRICHMENT_LEADMAGIC_API_KEY=
ENRICHMENT_HUNTER_API_KEY=
MAX_ENRICHMENT_COST_PER_LEAD=0.15

# Optional fallback: default Instantly campaign UUID for send-queue.
# Preferred: set public.integration_settings.instantly_default_campaign_id (id=1); see README.
INSTANTLY_DEFAULT_CAMPAIGN_ID=

# High-touch threshold (handwritten queue + phone scrape): change HIGH_TOUCH_MIN_SCORE in src/lib/scoring/hvac-rubric.ts (default 75).
